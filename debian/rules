#!/usr/bin/make -f

export DH_VERBOSE = 1
export DH_GOPKG := github.com/tg123/sshpiper
# `full` build tag includes the optional upstream plugins
# (docker/failtoban/fixed/lua/metrics/simplemath/username-router/yaml).
# Without it, those plugins' main.go is gated off by `//go:build full || e2e`
# and `go build` fails with "build constraints exclude all Go files".
# Harmless on cmd/sshpiperd which doesn't use the `full` tag.
export GOFLAGS := -mod=vendor -trimpath -tags=full
export GO111MODULE := on
# Launchpad builders have no network; vendored deps only.
export GOPROXY := off
# Pick the highest Go actually installed in the chroot. Build-Depends
# lists golang-1.25-go | golang-1.24-go, so apt resolves to whichever
# is available for the target series (1.25 on resolute Release, 1.24
# on noble-updates). build-source-package.sh already lowers upstream's
# `go 1.25.0` directive to `go 1.24` — newer Go compiles it fine.
#
# We DON'T hard-error here if Go isn't found, because `dpkg-buildpackage
# -S` runs the `clean` target on our CI runner (which has no Go
# installed) when producing the source package. The check moves to
# override_dh_auto_build where it actually matters.
GO_BINDIR := $(firstword $(wildcard /usr/lib/go-1.25/bin /usr/lib/go-1.24/bin))
ifneq ($(GO_BINDIR),)
export PATH := $(GO_BINDIR):$(PATH)
endif
# Belt-and-braces: never let Go try to fetch a different toolchain.
# Launchpad's GOPROXY=off would block it anyway, but this fails fast.
export GOTOOLCHAIN := local

BUILDDIR := $(CURDIR)/_build
BINDIR   := $(BUILDDIR)/bin

# Launchpad's sbuild sets HOME=/sbuild-nonexistent (a read-only canary
# path) to catch packages that try to write to $HOME during build. Go's
# defaults for GOCACHE / GOTMPDIR / GOMODCACHE are all under $HOME, so
# without overrides `go build` fails with "permission denied" on first
# invocation. Keep everything inside the build tree.
export GOCACHE := $(BUILDDIR)/.gocache
export GOTMPDIR := $(BUILDDIR)/.gotmp
export GOMODCACHE := $(BUILDDIR)/.gomodcache

# Plugins discovered at build time from plugin/*/main.go.
# Tweak this list if upstream layout changes.
PLUGINS := $(notdir $(patsubst %/,%,$(dir $(wildcard plugin/*/main.go))))

%:
	dh $@ --buildsystem=golang --with=golang

override_dh_auto_build:
	@if [ -z "$(GO_BINDIR)" ]; then \
		echo 'error: no /usr/lib/go-{1.25,1.24}/bin found — check Build-Depends' >&2; \
		exit 1; \
	fi
	mkdir -p $(BINDIR) $(GOCACHE) $(GOTMPDIR) $(GOMODCACHE)
	go build -o $(BINDIR)/sshpiperd ./cmd/sshpiperd
	for p in $(PLUGINS); do \
	  go build -o $(BINDIR)/sshpiperd-plugin-$$p ./plugin/$$p || exit 1; \
	done

override_dh_auto_install:
	# sshpiperd package
	install -D -m0755 $(BINDIR)/sshpiperd \
	  debian/sshpiperd/usr/sbin/sshpiperd
	install -d debian/sshpiperd/etc/sshpiperd
	install -d debian/sshpiperd/var/lib/sshpiperd
	# sshpiperd-plugins package
	for p in $(PLUGINS); do \
	  install -D -m0755 $(BINDIR)/sshpiperd-plugin-$$p \
	    debian/sshpiperd-plugins/usr/lib/sshpiperd/plugins/$$p; \
	done

override_dh_auto_test:
	# Skip upstream tests during package build — they need network/fixtures.

override_dh_dwz:
	# Skip DWARF-info deduplication. Go compresses its own debug sections,
	# so dwz refuses to touch them and returns exit 1 on jammy's older
	# dwz (exits 0 on newer versions like in noble/resolute). dh_dwz treats
	# exit 1 as failure and aborts the whole build. Skipping is the canonical
	# Debian Go-packaging workaround — no size savings are lost because
	# dwz wouldn't have done anything anyway.

override_dh_auto_clean:
	rm -rf $(BUILDDIR)
	dh_auto_clean
